post_install() {
  echo ""
  echo ">>> To enable and start the camera service, run:"
  echo ">>>   sudo systemctl enable --now cam-server"
  echo ""
  echo ">>> To use cameras as a regular user, add yourself to the 'video' group:"
  echo ">>>   sudo usermod -aG video \$USER"
  echo ">>> Then log out and log back in for the change to take effect."
  echo ""
}

post_upgrade() {
  post_install
}
